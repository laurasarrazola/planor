# Conguración del servidor Planor
PORT=4000
NODE_ENV=development

# Configuración de la base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
# DB_PASSWORD=
DB_NAME=planor

# Configuración de TypeORM
DB_TYPE=mysql
DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Configuración de JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=7d

# Configuración de CORS (CORS permite que el frontend se comunique con el backend)
CORS_ORIGIN=http://localhost:3000
